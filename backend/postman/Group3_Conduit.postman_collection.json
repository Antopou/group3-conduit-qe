{
	"info": {
		"name": "Group3_Conduit",
		"_postman_id": "group3-conduit-collection",
		"description": "Postman collection for Conduit API (10 requests)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000/api"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "userEmail",
			"value": ""
		},
		{
			"key": "articleSlug",
			"value": ""
		}
	],
	"item": [
		{
			"name": "1 - POST /users/login",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"url": { "raw": "{{baseUrl}}/users/login", "host": ["{{baseUrl}}"], "path": ["users","login"] },
				"body": {
					"mode": "raw",
					"raw": "{\n  \"user\": { \"email\": \"testuser@example.com\", \"password\": \"Password123!\" }\n}"
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
							"var json = pm.response.json();",
							"pm.test('Token exists', function () { pm.expect(json.user.token).to.be.a('string'); });",
							"pm.environment.set('token', json.user.token);",
							"pm.environment.set('userEmail', json.user.email);"
						]
					}
				}
			]
		},
		{
			"name": "2 - POST /users",
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] },
				"body": { "mode": "raw", "raw": "{\n  \"user\": { \"username\": \"testuser\", \"email\": \"testuser@example.com\", \"password\": \"Password123!\" }\n}" }
			},
			"event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 201', function () { pm.response.to.have.status(201); });", "var json = pm.response.json();", "pm.test('User object exists', function () { pm.expect(json.user).to.be.an('object'); });", "pm.environment.set('userEmail', json.user.email);" ] } } ]
		},
		{
			"name": "3 - GET /user",
			"request": {
				"method": "GET",
				"header": [ { "key": "Authorization", "value": "Token {{token}}" } ],
				"url": { "raw": "{{baseUrl}}/user", "host": ["{{baseUrl}}"], "path": ["user"] }
			},
			"event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 200', function () { pm.response.to.have.status(200); });", "var json = pm.response.json();", "pm.test('Email matches', function () { pm.expect(json.user.email).to.eql(pm.environment.get('userEmail')); });" ] } } ]
		},
		{
			"name": "4 - PUT /user",
			"request": {
				"method": "PUT",
				"header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Token {{token}}" } ],
				"url": { "raw": "{{baseUrl}}/user", "host": ["{{baseUrl}}"], "path": ["user"] },
				"body": { "mode": "raw", "raw": "{\n  \"user\": { \"bio\": \"Updated bio\" }\n}" }
			},
			"event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 200', function () { pm.response.to.have.status(200); });", "var json = pm.response.json();", "pm.test('Updated field present', function () { pm.expect(json.user.bio).to.eql('Updated bio'); });" ] } } ]
		},
		{
			"name": "5 - POST /articles",
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Token {{token}}" } ],
				"url": { "raw": "{{baseUrl}}/articles", "host": ["{{baseUrl}}"], "path": ["articles"] },
				"body": { "mode": "raw", "raw": "{\n  \"article\": { \"title\": \"Postman Article\", \"description\": \"desc\", \"body\": \"content\", \"tagList\": [\"postman\"] }\n}" }
			},
			"event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 201', function () { pm.response.to.have.status(201); });", "var json = pm.response.json();", "pm.test('Slug exists', function () { pm.expect(json.article.slug).to.be.a('string'); });", "pm.environment.set('articleSlug', json.article.slug);" ] } } ]
		},
		{
			"name": "6 - GET /articles",
			"request": {
				"method": "GET",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"url": { "raw": "{{baseUrl}}/articles", "host": ["{{baseUrl}}"], "path": ["articles"] }
			},
			"event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 200', function () { pm.response.to.have.status(200); });", "var json = pm.response.json();", "pm.test('Articles array', function () { pm.expect(json.articles).to.be.an('array'); });" ] } } ]
		},
		{
			"name": "7 - GET /articles/:slug",
			"request": {
				"method": "GET",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"url": { "raw": "{{baseUrl}}/articles/{{articleSlug}}", "host": ["{{baseUrl}}"], "path": ["articles","{{articleSlug}}"] }
			},
			"event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 200', function () { pm.response.to.have.status(200); });", "var json = pm.response.json();", "pm.test('Correct slug', function () { pm.expect(json.article.slug).to.eql(pm.environment.get('articleSlug')); });" ] } } ]
		},
		{
			"name": "8 - PUT /articles/:slug",
			"request": {
				"method": "PUT",
				"header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Token {{token}}" } ],
				"url": { "raw": "{{baseUrl}}/articles/{{articleSlug}}", "host": ["{{baseUrl}}"], "path": ["articles","{{articleSlug}}"] },
				"body": { "mode": "raw", "raw": "{\n  \"article\": { \"title\": \"Updated Title\" }\n}" }
			},
			"event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 200', function () { pm.response.to.have.status(200); });", "var json = pm.response.json();", "pm.test('Updated title', function () { pm.expect(json.article.title).to.eql('Updated Title'); });" ] } } ]
		},
		{
			"name": "9 - DELETE /articles/:slug",
			"request": {
				"method": "DELETE",
				"header": [ { "key": "Authorization", "value": "Token {{token}}" } ],
				"url": { "raw": "{{baseUrl}}/articles/{{articleSlug}}", "host": ["{{baseUrl}}"], "path": ["articles","{{articleSlug}}"] }
			},
			"event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 204', function () { pm.response.to.have.status(204); });" ] } } ]
		},
		{
			"name": "10 - POST /articles/:slug/comments",
			"request": {
				"method": "POST",
				"header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Token {{token}}" } ],
				"url": { "raw": "{{baseUrl}}/articles/{{articleSlug}}/comments", "host": ["{{baseUrl}}"], "path": ["articles","{{articleSlug}}","comments"] },
				"body": { "mode": "raw", "raw": "{\n  \"comment\": { \"body\": \"Nice article!\" }\n}" }
			},
			"event": [ { "listen": "test", "script": { "exec": [ "pm.test('Status is 200', function () { pm.response.to.have.status(200); });", "var json = pm.response.json();", "pm.test('Comment body', function () { pm.expect(json.comment.body).to.eql('Nice article!'); });" ] } } ]
		}
	]
}
