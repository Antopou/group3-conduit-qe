{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "module": "commonjs",
    "types": ["node"],
    "ignoreDeprecations": "6.0"
  },
  "exclude": [
    "jest.config.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/tests/**/*",
  ],
  "include": [
    "src/**/*.ts"
  ]
}
